{
  "name": "@naveenshaji/ui-feedback-agent",
  "version": "0.1.4",
  "description": "Dev-only UI feedback overlay for collecting agent-ready frontend change requests.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "demo:install": "npm --prefix demo install",
    "demo:dev": "npm --prefix demo run dev",
    "demo:build": "npm --prefix demo run build",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "ui",
    "feedback",
    "overlay",
    "react",
    "nextjs",
    "agent"
  ],
  "author": "Naveen Shaji",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/naveenshaji/ui-feedback-agent.git"
  },
  "homepage": "https://github.com/naveenshaji/ui-feedback-agent#readme",
  "bugs": {
    "url": "https://github.com/naveenshaji/ui-feedback-agent/issues"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
